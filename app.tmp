"""FastAPI application entrypoint."""

from __future__ import annotations

import logging
from contextlib import asynccontextmanager
from typing import AsyncIterator

from fastapi import FastAPI, Request
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import JSONResponse

from .api.cache import router as cache_router
from .api.health import router as health_router
from .api.synthesize import router as synthesize_router
from .api.voices import router as voices_router
from .config import Settings, get_settings
from .core.exceptions import BackendError
from .core.model import ModelManager
from .services.synth_cache import SynthCache
from .services.synthesize import SynthService
from .services.voices import VoiceRegistry

log = logging.getLogger(__name__)


def _configure_logging(level: str) -> None:
    logging.basicConfig(
        level=level.upper(),
        format="%(asctime)s %(levelname)-7s [%(name)s] %(message)s",
    )


def create_app(settings: Settings | None = None) -> FastAPI:
    settings = settings or get_settings()
    _configure_logging(settings.log_level)

    @asynccontextmanager
    async def lifespan(app: FastAPI) -> AsyncIterator[None]:
        # Eager load the model so /api/health is honest on first hit.
        mm: ModelManager = app.state.model_manager
        try:
            mm.load()
        except Exception:  # noqa: BLE001
            log.exception("Model failed to load at startup; serving in degraded mode.")
        try:
            yield
        finally:
            mm.unload()

    app = FastAPI(
        title="VibeVoice 1.5B TTS API",
        version="0.1.0",
        lifespan=lifespan,
    )

    # CORS — permissive for local dev. Tighten in production.
    app.add_middleware(
        CORSMiddleware,
        allow_origins=["*"],
        allow_credentials=False,
        allow_methods=["*"],
        allow_headers=["*"],
    )

    # ---- state singletons
    model_manager = ModelManager(
        model_id=settings.model_id,
        device_request=settings.device if settings.device != "auto" else "cuda",
    )
    voice_registry = VoiceRegistry(
        voices_dir=settings.voices_dir,
        uploads_dir=settings.uploads_dir,
    )
    synth_service = SynthService(
        model_manager=model_manager,
        voice_registry=voice_registry,
        max_text_chars=settings.max_text_chars,
        synth_timeout_s=settings.synth_timeout_s,
        default_cfg_scale=settings.default_cfg_scale,
    )

    app.state.settings = settings
    app.state.model_manager = model_manager
    app.state.voice_registry = voice_registry
    app.state.synth_service = synth_service

    # ---- routers
    app.include_router(health_router)
    app.include_router(voices_router)
    app.include_router(synthesize_router)

    # ---- streaming stub (501; planned for a later release)
    @app.websocket("/api/stream")
    async def _stream_stub(ws):  # pragma: no cover - never expected to be hit
        await ws.accept()
        await ws.send_json({"type": "error", "event": "not_implemented",
                             "message": "WebSocket streaming is planned for a future release."})
        await ws.close()

    # ---- exception handlers
    @app.exception_handler(BackendError)
    async def backend_error_handler(_: Request, exc: BackendError) -> JSONResponse:
        return JSONResponse(
            status_code=exc.http_status,
            content={"detail": exc.message, "code": exc.code},
        )

    @app.exception_handler(Exception)
    async def unhandled_exception_handler(request: Request, exc: Exception) -> JSONResponse:
        # Log the full traceback so we can see what's going wrong
        import traceback
        log.error("Unhandled exception in %s %s:\n%s", request.method, request.url.path, traceback.format_exc())
        return JSONResponse(
            status_code=500,
            content={
                "detail": f"{type(exc).__name__}: {exc}",
                "code": "internal_error",
            },
        )

    return app


# Module-level instance for `uvicorn backend.app:app`
app = create_app()
name__}: {exc}",
                "code": "internal_error",
            },
        )

    return app


# Module-level instance for `uvicorn backend.app:app`
app = create_app()
