# VibeVoice backend configuration
# Copy to `.env` and edit. CLI flags (--device, --port, etc.) override these.

# Model — HF id or local path. If local, point to a directory containing
# config.json and the model-*.safetensors files from microsoft/VibeVoice-1.5B.
MODEL_ID=microsoft/VibeVoice-1.5B

# Inference device. "auto" picks the best available (cuda > mps > cpu).
DEVICE=auto

# Server bind
HOST=0.0.0.0
PORT=8880

# Filesystem
VOICES_DIR=./voices
UPLOADS_DIR=./uploads
CACHE_DIR=./cache
CACHE_ENABLED=true
CACHE_MAX_ENTRIES=500

# Limits
MAX_TEXT_CHARS=5000
SYNTH_TIMEOUT_S=600

# Generation defaults
DEFAULT_CFG_SCALE=1.3

# uvicorn log level
LOG_LEVEL=info
